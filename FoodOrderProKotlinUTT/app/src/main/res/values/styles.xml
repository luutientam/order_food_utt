<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:statusBarColor">@color/brandOrangeDark</item>
        <item name="android:windowBackground">@color/screenBackground</item>
        <item name="android:textColor">@color/textColorPrimary</item>
    </style>

    <style name="PrimaryButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_primary_button</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_size_normal</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="OutlinedButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_outlined_button</item>
        <item name="android:textColor">@color/brandOrange</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_size_normal</item>
        <item name="android:minHeight">44dp</item>
    </style>

    <style name="CardSurface">
        <item name="android:background">@drawable/bg_card_surface</item>
        <item name="android:padding">@dimen/define_dimen_12</item>
    </style>

    <declare-styleable name="AspectRatioView">
        <attr name="aspectRatioEnabled" format="boolean" />
        <attr name="dominantMeasurement" format="enum">
            <enum name="Width" value="0" />
            <enum name="Height" value="1" />
        </attr>
        <attr name="aspectRatio" format="float" />

        <attr name="cornerRadius" format="dimension" />
        <attr name="roundedCorners">
            <flag name="topLeft" value="1" />
            <flag name="topRight" value="2" />
            <flag name="bottomRight" value="4" />
            <flag name="bottomLeft" value="8" />
            <flag name="all" value="15" />
        </attr>
    </declare-styleable>

    <declare-styleable name="ScrollControllableViewpager">
        <attr name="scrollable" format="boolean" />
    </declare-styleable>

    <attr name="itemActiveColor" format="color" />
    <attr name="itemInactiveColor" format="color" />
    <attr name="titleColorActive" format="color" />
    <attr name="titleColorInactive" format="color" />

    <declare-styleable name="PropertyBottomNavigation">
        <attr name="itemActiveColor"/>
        <attr name="itemInactiveColor"/>
        <attr name="titleColorActive"/>
        <attr name="titleColorInactive"/>
    </declare-styleable>

</resources>