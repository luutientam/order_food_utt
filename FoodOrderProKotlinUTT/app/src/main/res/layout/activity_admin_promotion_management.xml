<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <include
        android:id="@+id/toolbar"
        layout="@layout/layout_toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/define_dimen_12">

            <EditText
                android:id="@+id/edt_code"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_promotion_code"
                android:textAllCaps="true" />

            <EditText
                android:id="@+id/edt_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/define_dimen_8"
                android:hint="@string/promotion_title" />

            <EditText
                android:id="@+id/edt_discount_percent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/define_dimen_8"
                android:hint="@string/promotion_discount_percent"
                android:inputType="number" />

            <EditText
                android:id="@+id/edt_min_order"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/define_dimen_8"
                android:hint="@string/promotion_min_order"
                android:inputType="number" />

            <EditText
                android:id="@+id/edt_max_discount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/define_dimen_8"
                android:hint="@string/promotion_max_discount"
                android:inputType="number" />

            <TextView
                android:id="@+id/tv_add_promotion"
                android:layout_width="match_parent"
                android:layout_height="@dimen/define_dimen_40"
                android:layout_marginTop="@dimen/define_dimen_10"
                android:background="@drawable/bg_main_corner_8"
                android:gravity="center"
                android:text="@string/add_promotion"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rcv_promotion"
                android:layout_width="match_parent"
                android:layout_height="@dimen/define_dimen_420"
                android:layout_marginTop="@dimen/define_dimen_12" />
        </LinearLayout>
    </ScrollView>

</LinearLayout>
