<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layout_content"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screenBackground"
    android:visibility="gone"
    android:orientation="vertical">

    <RelativeLayout
        android:id="@+id/layout_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/brandOrange"
        android:paddingStart="@dimen/define_dimen_12"
        android:paddingEnd="@dimen/define_dimen_12"
        android:paddingTop="@dimen/define_dimen_12"
        android:paddingBottom="@dimen/define_dimen_12">

        <EditText
            android:id="@+id/edt_search_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_search_pill"
            android:hint="@string/hint_search_name"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:paddingStart="@dimen/define_dimen_18"
            android:paddingEnd="@dimen/define_dimen_44"
            android:paddingTop="@dimen/define_dimen_10"
            android:paddingBottom="@dimen/define_dimen_10"
            android:textColor="@color/textColorPrimary"
            android:textColorHint="@color/textColorAccent"
            android:textSize="@dimen/text_size_small"
            tools:ignore="Autofill" />

        <ImageView
            android:id="@+id/img_search"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="@dimen/define_dimen_18"
            android:padding="@dimen/define_dimen_5"
            android:src="@drawable/ic_search_red"
            tools:ignore="ContentDescription" />
    </RelativeLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcv_categories"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/define_dimen_10"
        android:paddingStart="@dimen/define_dimen_12"
        android:paddingEnd="@dimen/define_dimen_12"
        android:clipToPadding="false"
        android:orientation="horizontal" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/define_dimen_8"
        android:paddingStart="@dimen/define_dimen_12"
        android:paddingEnd="@dimen/define_dimen_12"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chip_price_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_selected"
                android:paddingStart="@dimen/define_dimen_14"
                android:paddingEnd="@dimen/define_dimen_14"
                android:paddingTop="@dimen/define_dimen_6"
                android:paddingBottom="@dimen/define_dimen_6"
                android:layout_marginEnd="@dimen/define_dimen_8"
                android:text="@string/price_chip_all"
                android:textColor="@color/white"
                android:textSize="@dimen/text_size_xsmall" />

            <TextView
                android:id="@+id/chip_price_low"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_unselected"
                android:paddingStart="@dimen/define_dimen_14"
                android:paddingEnd="@dimen/define_dimen_14"
                android:paddingTop="@dimen/define_dimen_6"
                android:paddingBottom="@dimen/define_dimen_6"
                android:layout_marginEnd="@dimen/define_dimen_8"
                android:text="@string/price_chip_low"
                android:textColor="@color/textColorPrimary"
                android:textSize="@dimen/text_size_xsmall" />

            <TextView
                android:id="@+id/chip_price_mid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_unselected"
                android:paddingStart="@dimen/define_dimen_14"
                android:paddingEnd="@dimen/define_dimen_14"
                android:paddingTop="@dimen/define_dimen_6"
                android:paddingBottom="@dimen/define_dimen_6"
                android:layout_marginEnd="@dimen/define_dimen_8"
                android:text="@string/price_chip_mid"
                android:textColor="@color/textColorPrimary"
                android:textSize="@dimen/text_size_xsmall" />

            <TextView
                android:id="@+id/chip_price_high"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_unselected"
                android:paddingStart="@dimen/define_dimen_14"
                android:paddingEnd="@dimen/define_dimen_14"
                android:paddingTop="@dimen/define_dimen_6"
                android:paddingBottom="@dimen/define_dimen_6"
                android:layout_marginEnd="@dimen/define_dimen_8"
                android:text="@string/price_chip_high"
                android:textColor="@color/textColorPrimary"
                android:textSize="@dimen/text_size_xsmall" />
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/define_dimen_10">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                tools:ignore="UselessParent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/viewpager_2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <me.relex.circleindicator.CircleIndicator3
                        android:id="@+id/indicator_3"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/define_dimen_30"
                        android:layout_gravity="center"
                        app:ci_drawable="@drawable/bg_indicatior_selected"
                        app:ci_drawable_unselected="@drawable/bg_indicatior_unselected" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/define_dimen_12"
                    android:layout_marginTop="@dimen/define_dimen_10"
                    android:layout_marginBottom="@dimen/define_dimen_5"
                    android:text="@string/food_suggest"
                    android:textColor="@color/textColorPrimary"
                    android:textSize="@dimen/text_size_normal"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rcv_food"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:focusable="false"
                    android:layout_marginStart="@dimen/define_dimen_10"
                    android:layout_marginEnd="@dimen/define_dimen_10"
                    android:layout_marginBottom="@dimen/define_dimen_10" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
